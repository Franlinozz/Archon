{
  "name": "archon",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "pnpm docs:generate && eslint . --max-warnings=0",
    "typecheck": "pnpm docs:generate && tsc --noEmit",
    "worker": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config worker/index.ts",
    "test": "tsx scripts/test-proof-hash.ts && tsx scripts/test-mantle-rules.ts && tsx scripts/test-gas-rules.ts",
    "compile:contracts": "rm -rf /tmp/archon-contracts-build && mkdir -p /tmp/archon-contracts-build && solcjs --bin --abi --base-path . -o /tmp/archon-contracts-build contracts/*.sol",
    "prepare": "husky",
    "secret-scan": "tsx scripts/secret-scan.ts",
    "scope-grep": "tsx scripts/scope-grep.ts",
    "docs:generate": "fumadocs-mdx source.config.ts",
    "whitepaper:pdf": "node scripts/generate-whitepaper-pdf.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "1.2.3",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@scalar/nextjs-api-reference": "0.11.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/mdx": "^2.0.14",
    "bullmq": "5.56.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^14.3.2",
    "ioredis": "5.6.1",
    "jszip": "3.10.1",
    "lucide-react": "0.468.0",
    "monaco-editor": "^0.55.1",
    "next": "15.5.9",
    "pdfkit": "^0.19.0",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "2.15.0",
    "solc-0-8-24": "npm:solc@0.8.24",
    "tailwind-merge": "2.6.0",
    "viem": "2.51.3",
    "wagmi": "2.16.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "0.5.9",
    "@types/node": "22.10.2",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "8.11.10",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.9",
    "husky": "9.1.7",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "sharp": "^0.34.5",
    "solc": "0.8.30",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@9.12.3"
}
