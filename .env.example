# --- App ---
NODE_ENV=production
APP_URL=https://archonaudit.xyz
APP_VERSION=2.0.0
# --- Database (Supabase) ---
DATABASE_URL=postgres://USER:PASSWORD@HOST:6543/postgres
# --- Queue / cache ---
REDIS_URL=redis://127.0.0.1:6379
# --- AI ---
OPENAI_API_KEY=
AI_PROMPT_VERSION=1
# --- Supabase public client fallback ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# --- Mantle Mainnet ---
MANTLE_RPC_URL=https://rpc.mantle.xyz
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_EXPLORER_API=
MANTLE_CHAIN_ID=5000
# --- Wallet (RainbowKit / WalletConnect) ---
# Optional WalletConnect Cloud projectId; enables WalletConnect wallets. Injected
# wallets (MetaMask/Rabby) work without it. Falls back to a placeholder if unset.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# --- ERC-8004 ---
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# ERC8004_VALIDATION_REGISTRY intentionally unset; official ERC-8004 README publishes no Mantle Mainnet Validation Registry
ERC8004_VALIDATION_REGISTRY=
ARCHON_AGENT_IDENTITY_REF=
ARCHON_PUBLIC_BASE_URL=https://archonaudit.xyz
# Dedicated non-owner wallet for ERC-8004 Reputation feedback; server-side only
ARCHON_REPUTATION_CLIENT_PRIVATE_KEY=
ARCHON_REPUTATION_CLIENT_ADDRESS=
ARCHON_REPUTATION_CLIENT_FUND_MNT=0.03
# --- Project wallet (server-side only) ---
ARCHON_WALLET_PRIVATE_KEY=
# --- IPFS pinning ---
IPFS_PIN_PROVIDER=pinata
# Server-side JWT from Pinata or another supported free IPFS pinning provider. If absent, Archon uses HTTPS metadata fallback.
IPFS_PIN_TOKEN=
# --- Tencent Cloud COS (optional artifact-backup; best-effort, never blocks IPFS/Postgres) ---
# All four required to activate the COS backup. Bucket name includes the APPID; region is the COS code (e.g. ap-hongkong).
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
# --- Tencent Cloud Hunyuan (optional LLM enrichment adapter; OpenAI gpt-4o-mini stays the active model unless this is set) ---
# TENCENT_HUNYUAN_KEY=
# --- Foundry test generation ---
FORK_BLOCK=latest
