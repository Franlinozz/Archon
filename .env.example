# --- App ---
NODE_ENV=production
APP_URL=https://archonaudit.xyz
APP_VERSION=2.0.0
# --- Database (Supabase) ---
DATABASE_URL=postgres://USER:PASSWORD@HOST:6543/postgres
# --- Queue / cache ---
REDIS_URL=redis://127.0.0.1:6379
# --- AI ---
OPENAI_API_KEY=
AI_PROMPT_VERSION=1
# --- Supabase public client fallback ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# --- Mantle Mainnet ---
MANTLE_RPC_URL=
MANTLE_EXPLORER_API=
MANTLE_CHAIN_ID=5000
# --- ERC-8004 ---
ERC8004_IDENTITY_REGISTRY=
ERC8004_REPUTATION_REGISTRY=
ERC8004_VALIDATION_REGISTRY=
ARCHON_AGENT_IDENTITY_REF=
# --- Project wallet (server-side only) ---
ARCHON_WALLET_PRIVATE_KEY=
# --- IPFS pinning ---
IPFS_PIN_PROVIDER=web3storage
IPFS_PIN_TOKEN=
# --- Foundry test generation ---
FORK_BLOCK=latest
